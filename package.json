{
  "name": "vibe-receipt",
  "version": "0.3.0",
  "description": "Per-session Spotify-Wrapped-style receipt cards for Claude Code & Codex CLI sessions",
  "keywords": [
    "claude-code",
    "codex",
    "ai-coding",
    "wrapped",
    "receipt",
    "satori"
  ],
  "author": "Loris Galler <loris307@github>",
  "license": "MIT",
  "homepage": "https://github.com/loris307/vibe-receipt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loris307/vibe-receipt.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19.4"
  },
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "vibe-receipt": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "assets/fonts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ccusage/codex": "^18.0.11",
    "@resvg/resvg-js": "^2.6.2",
    "ccusage": "^18.0.11",
    "chalk": "^5.6.2",
    "jsonc-parser": "^3.3.1",
    "ms": "^2.1.3",
    "react": "^18.3.1",
    "satori": "^0.10.14",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsdown": "^0.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
